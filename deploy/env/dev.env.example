# Dev / laptop — local compose testing (not for Pi deployment)
# Copy to deploy/env/dev.env and adjust DATA_REPO_HOST_PATH

COMPOSE_PROJECT_NAME=ai-sailing-dev
RACE_MODE=false
ONLINE_MODE=true

# Paths — sibling clone default on Windows
DATA_REPO_HOST_PATH=../AI-sailing-data

# InfluxDB (dev defaults — change before any real deployment)
INFLUX_ORG=ai-sailing
INFLUX_BUCKET=signalk
INFLUX_TOKEN=dev-influx-token-change-me
INFLUX_ADMIN_PASSWORD=dev-influx-admin-change-me

# Grafana
GRAFANA_ADMIN_PASSWORD=dev-grafana-change-me
GRAFANA_TELEMETRY_PORT=3001

# Signal K
SIGNALK_PORT=3000
SIGNALK_URL=http://signalk-server:3000
SIGNALK_WS_URL=ws://signalk-server:3000/signalk/v1/stream?subscribe=all
VESSEL_ID=own-boat

# polar-manager (SLA-2) — SLA-1 sidecar uses host.docker.internal when both stacks run on laptop
POLAR_MANAGER_PORT=8092
POLAR_MANAGER_URL=http://host.docker.internal:8092

# Neo4j
NEO4J_PASSWORD=dev-neo4j-change-me
NEO4J_USER=neo4j

# Race import / sync
SYNC_AUTO_PULL=false
SYNC_AUTO_IMPORT=true
RACE_IMPORT_PORT=8080

# MCP (optional — enable with: --profile mcp)
RACE_MCP_API_KEY=dev-mcp-key-change-me
NEO4J_MCP_PASSWORD=dev-mcp-neo4j-change-me
INFLUX_READ_TOKEN=dev-influx-token-change-me
