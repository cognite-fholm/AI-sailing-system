# Harbor mode — single env file for competition boats (ADR-0027)
# Copy to harbor.env on each Pi (not committed). Do NOT swap to race.env per regatta.
#
# Runtime policy (sync intervals, live sync, schedule) comes from AI-sailing-data
# via race-data-sync + race-lifecycle. See planning/runtime-policy.yaml and race.yaml.

RACE_MODE=false
WATCHTOWER_NO_PULL=true

# LTE / Wi-Fi — race-live-sync checks this before push
ONLINE_MODE=true

# Baseline enables; race-lifecycle gates actual pull/push by phase
SYNC_AUTO_PULL=true
SYNC_AUTO_IMPORT=true
SYNC_POLL_MINUTES=60
RACE_LIVE_SYNC_ENABLED=true
RACE_LIVE_SYNC_INTERVAL_MINUTES=5

# GitHub push token — install once: deploy/secrets/github_token (mode 600)
GITHUB_TOKEN_FILE=/run/secrets/github_token
GIT_USER_NAME=race-live-sync
GIT_USER_EMAIL=race-live-sync@boats.local

# MCP gateway for laptop Cursor at regatta
RACE_MCP_ENABLED=true

# Compose project name per host
COMPOSE_PROJECT_NAME=ai-sailing
