# DEPRECATED — use harbor.env only (ADR-0027)
#
# Competition boats no longer swap env files per regatta. Runtime policy
# (race mode, sync pull, live sync) is driven by AI-sailing-data:
#   index.yaml active + race.yaml schedule + planning/runtime-policy.yaml
#   via race-lifecycle on the Pi.
#
# Keep this file for local dev overrides only.

RACE_MODE=true
WATCHTOWER_NO_PULL=true
ONLINE_MODE=true
SYNC_AUTO_PULL=false
RACE_LIVE_SYNC_ENABLED=true
RACE_LIVE_SYNC_INTERVAL_MINUTES=5
GITHUB_TOKEN_FILE=/run/secrets/github_token
COMPOSE_PROJECT_NAME=ai-sailing
