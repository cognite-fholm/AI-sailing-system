# Race mode — freeze deployments; no auto-pull; no training export
# Copy to race.env (or symlink as active env) before regatta

RACE_MODE=true
WATCHTOWER_NO_PULL=true
ONLINE_MODE=false

# Stops harbor-only services (set in compose profiles)
TRAINING_EXPORT_ENABLED=false

# MCP gateway for laptop Cursor — STAYS ENABLED during race (read-only analysis)
RACE_MCP_ENABLED=true
RACE_MCP_API_KEY=change-me-per-regatta

COMPOSE_PROJECT_NAME=ai-sailing
